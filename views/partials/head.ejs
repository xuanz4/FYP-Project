<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <% const roleClass = String(currentRole || 'guest').toLowerCase().replace(/[^a-z0-9]+/g, '-'); %>
  <body class="app-shell role-<%= roleClass %><%= typeof bodyClass !== 'undefined' && bodyClass ? ` ${bodyClass}` : '' %>">
    <%- include('sidebar', { activePage }) %>
