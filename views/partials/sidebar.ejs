<aside class="sidebar">
  <div class="brand">
    <div class="brand-mark">TC</div>
    <div>
      <strong>UNIWEB</strong>
      <span>Transaction Monitor</span>
    </div>
  </div>
  <nav>
    <% if (currentRole==='Admin' ) { %>
      <a class="<%= activePage === 'admin' ? 'active' : '' %>" href="/admin">Admin Overview</a>
      <a class="<%= activePage === 'admin-users' ? 'active' : '' %>" href="/admin/users">User Management</a>
      <a class="<%= activePage === 'admin-merchants' ? 'active' : '' %>" href="/admin/merchants">Merchant Management</a>
      <a class="<%= activePage === 'admin-rules' ? 'active' : '' %>" href="/admin/rules">Rule Management</a>
      <a class="<%= activePage === 'admin-audit-log' ? 'active' : '' %>" href="/admin/audit-log">Audit Log</a>
      <% } else if (currentRole==='Analyst' ) { %>
        <a class="<%= activePage === 'analyst' ? 'active' : '' %>" href="/analyst">Analyst Overview</a>
        <a class="<%= activePage === 'analyst-live-transactions' ? 'active' : '' %>" href="/analyst/live-transactions">Live Transaction Feed</a>
        <a class="<%= activePage === 'analyst-working-queue' ? 'active' : '' %>" href="/analyst/working-queue">Operations Working Queue</a>
        <a class="<%= activePage === 'analyst-cases' ? 'active' : '' %>" href="/analyst/cases">Cases</a>
        <a class="<%= activePage === 'analyst-audit-log' ? 'active' : '' %>" href="/analyst/audit-log">Audit Log</a>
        <% } else if (currentRole==='Senior Analyst' ) { %>
          <a class="<%= activePage === 'senior-analyst' ? 'active' : '' %>" href="/senior-analyst">Senior Analyst Overview</a>
          <a class="<%= activePage === 'senior-analyst-cases' ? 'active' : '' %>" href="/senior-analyst/cases">Cases Pending Review</a>
          <a class="<%= activePage === 'senior-analyst-audit-log' ? 'active' : '' %>" href="/senior-analyst/audit-log">Audit Log</a>
          <% } else if (currentRole==='STRO' ) { %>
            <a class="<%= activePage === 'stro' ? 'active' : '' %>" href="/stro">STRO Overview</a>
            <a class="<%= activePage === 'stro-cases' ? 'active' : '' %>" href="/stro/cases">Cases</a>
            <a class="<%= activePage === 'stro-str-reports' ? 'active' : '' %>" href="/stro/str-reports">STR Reports</a>
            <a class="<%= activePage === 'stro-audit-log' ? 'active' : '' %>" href="/stro/audit-log">Audit Log</a>
            <% } else { %>
            <a class="<%= activePage === 'dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a>
            <a class="<%= activePage === 'analytics' ? 'active' : '' %>" href="/analytics">Analytics</a>
            <a class="<%= activePage === 'diligence' ? 'active' : '' %>" href="/diligence">Due Diligence</a>
            <a class="<%= activePage === 'investigations' ? 'active' : '' %>" href="/investigations">Investigations</a>
            <a class="<%= activePage === 'rules' ? 'active' : '' %>" href="/rules">Rules</a>
            <% } %>
              <a href="/logout">Logout</a>
  </nav>
  <div class="connection">
    <span id="connectionDot"></span>
    <p id="connectionText">Connecting</p>
  </div>
</aside>
