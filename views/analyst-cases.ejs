<%- include('partials/head', { title, activePage }) %>

<%
  const fmtDate = (value) => value ? new Date(value).toLocaleString('en-SG', { timeZone: 'Asia/Singapore' }) : 'Not assigned';
  const statusLabel = (value) => ({ Open: 'New', 'Pending RFI': 'Waiting for Information', 'Pending Senior Review': 'Escalated to Senior Analyst', Escalated: 'Escalated to STRO' }[value] || value || 'New');
  const isOverdue = (item) => item.due_at && new Date(item.due_at).getTime() < Date.now() && !['Resolved','Dismissed as False Positive','STR Filed'].includes(item.status);
  const params = new URLSearchParams(filters);
  const pageLink = (page) => { const next = new URLSearchParams(params); next.set('page', page); return `/analyst/cases?${next.toString()}`; };
%>

<main class="analyst-page">
  <section class="analyst-page-header">
    <div>
      <p class="detail-eyebrow">UNIWEB analyst workspace</p>
      <h1>Cases</h1>
      <p>Cases opened from flagged transactions and tracked across the investigation lifecycle.</p>
    </div>
    <span class="role-chip">Analyst</span>
  </section>

  <section class="summary-grid compact">
    <article><span>Open Cases</span><strong><%= Number(summary.open_cases || 0) %></strong></article>
    <article><span>Waiting for Information</span><strong><%= Number(summary.waiting || 0) %></strong></article>
    <article><span>Escalated to Senior Analyst</span><strong><%= Number(summary.senior || 0) %></strong></article>
    <article><span>Referred to STRO</span><strong><%= Number(summary.stro || 0) %></strong></article>
    <article><span>Overdue</span><strong><%= Number(summary.overdue || 0) %></strong></article>
  </section>

  <form class="analyst-filter-bar" method="get">
    <label><span>Risk Level</span><select name="riskLevel"><option value="">All</option><% ['Low','Medium','High','Critical'].forEach((item) => { %><option value="<%= item %>" <%= filters.riskLevel === item ? 'selected' : '' %>><%= item %></option><% }) %></select></label>
    <label><span>Assessment Status</span><select name="assessmentStatus"><option value="">All</option><% ['Open','Under Review','Pending RFI','Pending Senior Review','Escalated','Resolved','Dismissed as False Positive','STR Filed'].forEach((item) => { %><option value="<%= item %>" <%= filters.assessmentStatus === item ? 'selected' : '' %>><%= statusLabel(item) %></option><% }) %></select></label>
    <label><span>Assigned Role</span><select name="assignedRole"><option value="">All</option><% ['Senior Analyst','STRO'].forEach((item) => { %><option value="<%= item %>" <%= filters.assignedRole === item ? 'selected' : '' %>><%= item %></option><% }) %></select></label>
    <label><span>Assigned Analyst</span><select name="assignedTo"><option value="">All</option><% filterOptions.users.forEach((item) => { %><option value="<%= item.user_id %>" <%= filters.assignedTo === item.user_id ? 'selected' : '' %>><%= item.user_name %></option><% }) %></select></label>
    <label><span>Escalated To</span><select name="escalatedTo"><option value="">All</option><option value="Senior Analyst" <%= filters.escalatedTo === 'Senior Analyst' ? 'selected' : '' %>>Senior Analyst</option><option value="STRO" <%= filters.escalatedTo === 'STRO' ? 'selected' : '' %>>STRO</option></select></label>
    <label><span>Decision</span><select name="decision"><option value="">All</option><option value="Accepted" <%= filters.decision === 'Accepted' ? 'selected' : '' %>>Accepted</option><option value="Rejected" <%= filters.decision === 'Rejected' ? 'selected' : '' %>>Rejected</option></select></label>
    <label><span>Due Status</span><select name="dueStatus"><option value="">All</option><option value="overdue" <%= filters.dueStatus === 'overdue' ? 'selected' : '' %>>Overdue</option><option value="notAssigned" <%= filters.dueStatus === 'notAssigned' ? 'selected' : '' %>>Not assigned</option></select></label>
    <label><span>Search</span><input name="q" value="<%= filters.q %>" placeholder="Case, transaction, merchant"></label>
    <button class="secondary-btn" type="submit">Apply</button>
  </form>

  <section class="panel">
    <div class="table-wrap analyst-table-wrap">
      <table class="analyst-table">
        <thead><tr><th>Case ID</th><th>Transaction</th><th>Created</th><th>Merchant</th><th class="num">Amount</th><th>Due Date</th><th class="num">Initial Weighted Score</th><th class="center">Rules Triggered</th><th>Risk Level</th><th>Assessment Status</th><th>Assigned To</th><th>Escalated To</th><th>Decision</th><th>Action</th></tr></thead>
        <tbody>
          <% if (rows.length) { rows.forEach((item) => { %>
            <tr class="<%= item.risk_level === 'Critical' ? 'priority-critical' : '' %>">
              <td><strong><%= item.case_id %></strong><% if (item.risk_level === 'Critical') { %><div><span class="status-pill status-critical">Needs Senior Review</span></div><% } %><% if (item.escalation_destination === 'STRO') { %><div><span class="status-pill status-escalated">Referred to STRO</span></div><% } %></td>
              <td><%= item.transaction_id %></td>
              <td><%= fmtDate(item.created_at) %></td>
              <td><strong><%= item.merchant_name || 'Unknown Merchant' %></strong><div class="muted">MCC <%= item.mcc_code || 'N/A' %></div></td>
              <td class="num">SGD <%= Number(item.amount || 0).toFixed(2) %></td>
              <td><%= fmtDate(item.due_at) %> <% if (isOverdue(item)) { %><span class="status-pill status-critical">Overdue</span><% } %></td>
              <td class="num"><%= item.risk_score ?? 'Not available' %></td>
              <td class="center"><%= item.rules_count ?? 'Not available' %></td>
              <td><span class="risk-badge risk-<%= String(item.risk_level || 'low').toLowerCase() %>"><%= item.risk_level || 'Low' %></span></td>
              <td><%= statusLabel(item.status) %></td>
              <td><%= item.assigned_user_name || item.assigned_role || 'Unassigned' %></td>
              <td><%= item.escalation_destination || 'Not assigned' %></td>
              <td><%= item.decision || 'Not assigned' %></td>
              <td><a class="secondary-btn" href="/transactions/<%= item.transaction_id %>">Review Case</a></td>
            </tr>
          <% }) } else { %>
            <tr><td colspan="14" class="empty-inline">No cases match the selected filters.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="pagination-row">
      <a class="secondary-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pageLink(Math.max(1, pagination.page - 1)) %>">Previous</a>
      <span>Page <%= pagination.page %> of <%= pagination.totalPages %> · <%= pagination.total %> records</span>
      <a class="secondary-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" href="<%= pageLink(Math.min(pagination.totalPages, pagination.page + 1)) %>">Next</a>
    </div>
  </section>
</main>

<%- include('partials/footer', { includeClientScript: true }) %>
