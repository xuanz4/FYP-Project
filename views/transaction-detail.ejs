<%- include('partials/head', { title, activePage }) %>

    <main class="transaction-detail-page">
        <section class="topbar detail-topbar">
            <div>
                <a class="back-link"
                    href="<%= currentRole === 'Admin' ? '/admin' : currentRole === 'STRO' ? '/stro' : '/analyst' %>">&larr;
                    Back to Dashboard</a>
                <h1>Transaction Review</h1>
                <% if (transaction) { %>
                    <p>
                        <%= transaction.transaction_id %>
                    </p>
                    <% } else { %>
                        <p>Transaction not found.</p>
                        <% } %>
            </div>
        </section>

        <% if (!transaction) { %>
            <section class="panel">
                <p class="muted">The transaction could not be loaded.</p>
            </section>
            <% } else { %>
                <section class="panel">
                    <div class="panel-header">
                        <div>
                            <h2>Transaction Details</h2>
                            <p>Merchant, risk, and case context.</p>
                        </div>
                    </div>
                    <div class="detail-grid">
                        <article><span>Transaction ID</span><strong>
                                <%= transaction.transaction_id %>
                            </strong></article>
                        <article><span>Merchant</span><strong>
                                <%= transaction.merchant_name || transaction.merchant_id %>
                            </strong></article>
                        <article><span>Amount</span><strong>
                                <%= Number(transaction.amount).toFixed(2) %>
                            </strong></article>
                        <article><span>Risk Level</span><strong>
                                <%= transaction.risk_level %>
                            </strong></article>
                        <article><span>Status</span><strong>
                                <%= transaction.status %>
                            </strong></article>
                        <article><span>Action Status</span><strong>
                                <%= transaction.action_status %>
                            </strong></article>
                        <article><span>Created</span><strong>
                                <%= new Date(transaction.created_at).toLocaleString('en-SG') %>
                            </strong></article>
                        <article><span>Updated</span><strong>
                                <%= transaction.updated_at ? new Date(transaction.updated_at).toLocaleString('en-SG')
                                    : 'Not updated' %>
                            </strong></article>
                    </div>
                </section>

                <section class="panel">
                    <div class="panel-header">
                        <div>
                            <h2>Case Context</h2>
                            <p>Open or resolve the linked case from this review screen.</p>
                        </div>
                    </div>
                    <% if (caseRecord) { %>
                        <div class="detail-grid">
                            <article><span>Case ID</span><strong>
                                    <%= caseRecord.case_id %>
                                </strong></article>
                            <article><span>Status</span><strong>
                                    <%= caseRecord.status %>
                                </strong></article>
                            <article><span>Created By</span><strong>
                                    <%= caseRecord.created_by %>
                                </strong></article>
                            <article><span>Assigned To</span><strong>
                                    <%= caseRecord.assigned_to || 'Unassigned' %>
                                </strong></article>
                            <article class="wide"><span>Notes</span><strong>
                                    <%= caseRecord.notes || 'No notes' %>
                                </strong></article>
                        </div>
                        <% } else { %>
                            <p class="muted">No case exists for this transaction yet.</p>
                            <% } %>
                </section>

                <% if (currentRole==='Analyst' ) { %>
                    <section class="panel">
                        <div class="panel-header">
                            <div>
                                <h2>Analyst Actions</h2>
                                <p>Create a case or update the existing one.</p>
                            </div>
                        </div>
                        <% if (!caseRecord) { %>
                            <form method="post" action="/analyst/cases" class="grid-form compact-form">
                                <input type="hidden" name="transactionId" value="<%= transaction.transaction_id %>">
                                <label><span>Assigned To</span><input name="assignedTo"></label>
                                <label><span>Notes</span><input name="notes"></label>
                                <button type="submit" class="primary-btn">Open Case</button>
                            </form>
                            <% } else { %>
                                <div class="table-actions">
                                    <form method="post" action="/analyst/cases/<%= caseRecord.case_id %>/action"><input
                                            type="hidden" name="action" value="rfi"><button type="submit"
                                            class="secondary-btn">Request RFI</button></form>
                                    <form method="post" action="/analyst/cases/<%= caseRecord.case_id %>/action"><input
                                            type="hidden" name="action" value="escalate"><button type="submit"
                                            class="secondary-btn">Escalate</button></form>
                                    <form method="post" action="/analyst/cases/<%= caseRecord.case_id %>/action"><input
                                            type="hidden" name="action" value="dismiss"><button type="submit"
                                            class="secondary-btn danger">Dismiss as False Positive</button></form>
                                </div>
                                <% } %>
                    </section>
                    <% } %>

                        <% if (currentRole==='STRO' && caseRecord) { %>
                            <section class="panel">
                                <div class="panel-header">
                                    <div>
                                        <h2>STRO Actions</h2>
                                        <p>Resolve an escalated case.</p>
                                    </div>
                                </div>
                                <div class="table-actions">
                                    <form method="post" action="/stro/cases/<%= caseRecord.case_id %>/action"><input
                                            type="hidden" name="action" value="dismiss"><button type="submit"
                                            class="secondary-btn danger">Dismiss as False Positive</button></form>
                                    <form method="post" action="/stro/cases/<%= caseRecord.case_id %>/action"><input
                                            type="hidden" name="action" value="str"><button type="submit"
                                            class="secondary-btn">File STR</button></form>
                                </div>
                            </section>
                            <% } %>
                                <% } %>
    </main>

    <%- include('partials/footer', { includeClientScript: false }) %>
        typeof activityLogs !== 'undefined' && Array.isArray(activityLogs)
        ? activityLogs
        : [];
        %>
        <% if (safeActivityLogs.length> 0) { %>
            <section class="panel detail-section">
                <div class="panel-header">
                    <div>
                        <h2>Activity Log</h2>
                        <p>Timeline for this transaction only.</p>
                    </div>
                </div>
                <div id="transactionActivityLog" class="transaction-activity-list">
                    <% safeActivityLogs.forEach((entry)=> { %>
                        <article class="transaction-activity-item">
                            <time>
                                <%= new Date(entry.createdAt).toLocaleTimeString('en-SG') %>
                            </time>
                            <div>
                                <strong>
                                    <%= entry.action %>
                                </strong>
                                <p>
                                    <%= entry.message || '' %>
                                </p>
                                <span>
                                    <%= entry.actor || 'System' %> &middot; <%= new
                                            Date(entry.createdAt).toLocaleString('en-SG') %>
                                </span>
                            </div>
                        </article>
                        <% }); %>
                </div>
            </section>
            <% } %>

                <div id="transactionActionModal" class="detail-modal action-modal" aria-hidden="true">
                    <div class="detail-modal-backdrop" data-close-transaction-action></div>
                    <section class="detail-dialog action-dialog" role="dialog" aria-modal="true"
                        aria-labelledby="transactionActionTitle">
                        <button type="button" class="detail-close" data-close-transaction-action
                            aria-label="Close action form">Close</button>
                        <div class="detail-heading">
                            <div>
                                <span class="eyebrow">Demo Form</span>
                                <h2 id="transactionActionTitle">Transaction Action</h2>
                                <p>This form is for demonstration only and does not submit to a backend.</p>
                            </div>
                        </div>
                        <form id="transactionActionForm" class="action-form">
                            <input id="transactionActionType" type="hidden" name="action" value="">
                            <label>
                                <span>Name</span>
                                <input id="transactionActionName" name="name" type="text" readonly
                                    value="<%= transaction.customerName %>">
                            </label>
                            <label>
                                <span>Amount</span>
                                <input id="transactionActionAmount" name="amount" type="text" readonly
                                    value="<%= moneyFormatter.format(transaction.amount) %>">
                            </label>
                            <label>
                                <span>Transaction Location</span>
                                <input id="transactionActionCountry" name="country" type="text" readonly
                                    value="<%= transaction.country %>">
                            </label>
                            <label>
                                <span>Merchant Category</span>
                                <input id="transactionActionCategory" name="merchantCategory" type="text" readonly
                                    value="<%= transaction.merchantCategory %>">
                            </label>
                            <label>
                                <span>MCC / Industry</span>
                                <input name="industry" type="text" readonly
                                    value="<%= transaction.mccCode || 'N/A' %> / <%= transaction.industry || 'N/A' %>">
                            </label>
                            <label>
                                <span>Analyst Notes</span>
                                <textarea name="notes" rows="4" required minlength="10"
                                    placeholder="Enter at least 10 meaningful characters"></textarea>
                            </label>
                            <button id="transactionActionSubmit" type="submit" class="action-submit">Submit</button>
                        </form>
                    </section>
                </div>
                <div id="rfiEmailModal" class="detail-modal action-modal" aria-hidden="true">
                    <div class="detail-modal-backdrop" data-close-rfi-modal></div>
                    <section class="detail-dialog action-dialog rfi-dialog" role="dialog" aria-modal="true"
                        aria-labelledby="rfiEmailTitle">
                        <button type="button" class="detail-close" data-close-rfi-modal
                            aria-label="Close RFI form">Close</button>
                        <div class="detail-heading">
                            <div>
                                <span class="eyebrow">Customer Verification</span>
                                <h2 id="rfiEmailTitle">Request for Information</h2>
                                <p>Send a neutral customer-facing verification request.</p>
                            </div>
                        </div>
                        <form id="rfiEmailForm" class="action-form">
                            <p class="rfi-warning">
                                Use neutral verification wording. Do not disclose internal risk scores, screening
                                results, suspicious transaction reporting, or investigation details to the customer.
                            </p>
                            <p id="rfiTestModeNotice"
                                class="rfi-test-mode-notice <%= emailTestMode ? '' : 'is-hidden' %>">
                                Development mode: Email will be captured by Ethereal and will not be delivered to the
                                real customer.
                            </p>
                            <label>
                                <span>Recipient Type</span>
                                <input id="rfiRecipientType" type="text" readonly
                                    value="<%= transaction.accountType || 'Individual' %>">
                            </label>
                            <label>
                                <span>Recipient Name</span>
                                <input id="rfiRecipientName" type="text" readonly
                                    value="<%= transaction.accountType === 'Organisation' ? (transaction.authorisedContactName || transaction.customerName) : transaction.customerName %>">
                            </label>
                            <label>
                                <span id="rfiRecipientEmailLabel">
                                    <%= transaction.accountType==='Organisation' ? 'Authorised contact email'
                                        : 'Customer email' %>
                                </span>
                                <input id="rfiRecipientEmail" type="email" readonly
                                    value="<%= transaction.accountType === 'Organisation' ? (transaction.authorisedContactEmail || '') : (transaction.customerEmail || '') %>">
                                <small id="rfiRecipientEmailHelp">Saved customer contact. In Ethereal test mode, the
                                    email is captured in a preview inbox and is not delivered to this address.</small>
                            </label>
                            <label class="full-span">
                                <span>Subject</span>
                                <input name="subject" type="text" required
                                    value="Additional Information Required for Your Transaction">
                            </label>
                            <label class="full-span">
                                <span>Information Requested</span>
                                <textarea name="informationRequested" rows="4" required minlength="10"
                                    placeholder="Please provide the invoice and source-of-funds documents."></textarea>
                            </label>
                            <div id="rfiEmailPreview" class="email-preview is-hidden"></div>
                            <p id="rfiEmailFeedback" class="muted"></p>
                            <div class="modal-actions">
                                <button type="button" class="secondary-btn" data-close-rfi-modal>Cancel</button>
                                <button id="rfiPreviewButton" type="button" class="secondary-btn">Preview Email</button>
                                <button id="rfiSendButton" type="submit" class="action-submit">Send RFI</button>
                            </div>
                        </form>
                    </section>
                </div>
                <% } %>
                    </main>

                    <%- include('partials/footer') %>