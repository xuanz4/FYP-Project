<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="login-page">
    <div class="login-bg-grid" aria-hidden="true"></div>
    <main class="login-shell">
        <section class="login-hero">
            <div class="login-brand-row">
                <div class="brand-mark login-brand-mark">TM</div>
                <div>
                    <span class="login-brand-kicker">UNIWEB</span>
                    <strong>Transaction Monitor</strong>
                </div>
            </div>
            <div>
                <span class="login-status-pill">Secure review workspace</span>
                <h1>Transaction Monitor</h1>
                <p>Monitor payment activity, review flagged alerts, route cases, and prepare compliance decisions from one protected workspace.</p>
            </div>
            <div class="login-role-strip" aria-label="Authorised roles">
                <span>Admin</span>
                <span>Analyst</span>
                <span>Senior Analyst</span>
                <span>STRO</span>
            </div>
            <div class="login-preview" aria-label="Security controls">
                <div class="login-preview-header">
                    <span>Private Access</span>
                    <strong>Role-based case review</strong>
                </div>
                <div class="login-security-visual" aria-hidden="true">
                    <div class="security-ring">
                        <span>TM</span>
                    </div>
                    <div class="security-lines">
                        <i></i>
                        <i></i>
                        <i></i>
                    </div>
                </div>
                <div class="login-privacy-list">
                    <span>Session-protected tools</span>
                    <span>Audit-ready activity trail</span>
                    <span>Controlled reviewer access</span>
                </div>
            </div>
        </section>
        <section class="login-card">
            <div class="login-card-accent">Secure workspace</div>
            <div class="login-card-header">
                <div class="login-card-icon">ID</div>
                <div>
                    <h2>Secure Sign In</h2>
                    <p>Use your assigned User ID and password.</p>
                </div>
            </div>
            <% if (error) { %>
                <div class="alert-banner">
                    <%= error %>
                </div>
                <% } %>
                    <form method="post" action="/auth/login" class="login-form">
                        <label>
                            <span>User ID</span>
                            <input type="text" name="userId" autocomplete="username" required>
                        </label>
                        <label>
                            <span>Password</span>
                            <input type="password" name="password" autocomplete="current-password" required>
                        </label>
                        <button type="submit" class="primary-btn">Sign In</button>
                    </form>
                    <div class="login-card-footer">
                        <span>Protected access</span>
                        <span>Session timeout enforced</span>
                    </div>
        </section>
    </main>
</body>

</html>
