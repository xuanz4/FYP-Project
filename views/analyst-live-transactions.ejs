<%- include('partials/head', { title, activePage }) %>

<%
  const params = new URLSearchParams(filters);
  const pageLink = (page) => {
    const next = new URLSearchParams(params);
    next.set('page', page);
    return `/analyst/live-transactions?${next.toString()}`;
  };
  const fmtDate = (value) => value ? new Date(value).toLocaleString('en-SG') : 'Not assigned';
%>

<main class="analyst-page">
  <section class="analyst-page-header">
    <div>
      <p class="detail-eyebrow">UNIWEB analyst workspace</p>
      <h1>Live Transaction Feed</h1>
      <p>All transactions visible to analysts, ordered newest first.</p>
    </div>
    <span class="role-chip">Analyst</span>
  </section>

  <form class="analyst-filter-bar" method="get">
    <label><span>Risk Level</span><select name="riskLevel"><option value="">All</option><% ['Low','Medium','High','Critical'].forEach((item) => { %><option value="<%= item %>" <%= filters.riskLevel === item ? 'selected' : '' %>><%= item %></option><% }) %></select></label>
    <label><span>Transaction Status</span><select name="transactionStatus"><option value="">All</option><% ['Cleared','Flagged'].forEach((item) => { %><option value="<%= item %>" <%= filters.transactionStatus === item ? 'selected' : '' %>><%= item %></option><% }) %></select></label>
    <label><span>Merchant Profile</span><select name="merchantId"><option value="">All</option><% filterOptions.merchants.forEach((item) => { %><option value="<%= item.merchant_id %>" <%= filters.merchantId === item.merchant_id ? 'selected' : '' %>><%= item.merchant_name %></option><% }) %></select></label>
    <label><span>Search</span><input name="q" value="<%= filters.q %>" placeholder="Transaction ID"></label>
    <button class="secondary-btn" type="submit">Apply</button>
  </form>

  <section class="panel">
    <div class="table-wrap analyst-table-wrap" data-live-refresh>
      <table class="analyst-table">
        <thead><tr><th>Transaction</th><th>Created</th><th>Merchant</th><th>Card</th><th class="num">Amount</th><th>Risk Level</th><th>Transaction Status</th><th>Action Status</th><th>Review</th></tr></thead>
        <tbody>
          <% if (rows.length) { rows.forEach((item) => { %>
            <tr>
              <td><strong><%= item.transaction_id %></strong><div class="muted"><%= item.transaction_code || '' %></div></td>
              <td><%= fmtDate(item.txn_time || item.created_at) %></td>
              <td title="<%= item.merchant_name || 'Unknown Merchant' %>"><strong><%= item.merchant_name || 'Unknown Merchant' %></strong><div class="muted">MCC <%= item.mcc_code || 'N/A' %></div></td>
              <td><%= (item.scheme || '').toUpperCase() %><div class="muted"><%= item.issuer_country || '' %> · <%= item.entry_mode || '' %></div></td>
              <td class="num">SGD <%= Number(item.amount || 0).toFixed(2) %></td>
              <td><span class="risk-badge risk-<%= String(item.risk_level || 'low').toLowerCase() %>"><%= item.risk_level || 'Low' %></span></td>
              <td><span class="status-pill status-<%= String(item.status || '').toLowerCase() %>"><%= item.status || 'Not assigned' %></span></td>
              <td><%= item.action_status || 'None' %></td>
              <td><a class="secondary-btn" href="/transactions/<%= item.transaction_id %>">Review</a></td>
            </tr>
          <% }) } else { %>
            <tr><td colspan="9" class="empty-inline">No transactions match the selected filters.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="pagination-row">
      <a class="secondary-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pageLink(Math.max(1, pagination.page - 1)) %>">Previous</a>
      <span>Page <%= pagination.page %> of <%= pagination.totalPages %> · <%= pagination.total %> records</span>
      <a class="secondary-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" href="<%= pageLink(Math.min(pagination.totalPages, pagination.page + 1)) %>">Next</a>
    </div>
  </section>
</main>

<%- include('partials/footer', { includeClientScript: true }) %>
