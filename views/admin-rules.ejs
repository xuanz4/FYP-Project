<%- include('partials/head', { title, activePage }) %>
<%
  const params = new URLSearchParams(filters);
  const pageLink = (page) => { const next = new URLSearchParams(params); next.set('page', page); return `/admin/rules?${next.toString()}`; };
  const threshold = (rule) => rule.amount_threshold ? `Amount > SGD ${Number(rule.amount_threshold).toFixed(2)}` : rule.count_threshold ? `${rule.count_threshold} transactions` : 'No threshold';
%>

<main class="analyst-page">
  <section class="analyst-page-header">
    <div><p class="detail-eyebrow">UNIWEB administration</p><h1>Rule Management</h1><p>Configure monitoring rules and merchant-specific thresholds.</p></div>
    <button class="primary-btn" type="button" data-open-dialog="createRuleDialog">Create Rule</button>
  </section>

  <form class="analyst-filter-bar" method="get">
    <label><span>Merchant</span><select name="merchantId"><option value="">All</option><% merchants.forEach((item) => { %><option value="<%= item.merchant_id %>" <%= filters.merchantId === item.merchant_id ? 'selected' : '' %>><%= item.merchant_name %></option><% }) %></select></label>
    <label><span>Risk Level</span><select name="riskLevel"><option value="">All</option><% ['Low','Medium','High','Critical'].forEach((item) => { %><option value="<%= item %>" <%= filters.riskLevel === item ? 'selected' : '' %>><%= item %></option><% }) %></select></label>
    <label><span>Rule Type</span><select name="ruleType"><option value="">All</option><% ruleTypes.forEach((item) => { %><option value="<%= item.rule_type %>" <%= filters.ruleType === item.rule_type ? 'selected' : '' %>><%= item.rule_type %></option><% }) %></select></label>
    <label><span>Status</span><select name="status"><option value="">All</option><option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option><option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option></select></label>
    <label><span>Search</span><input name="q" value="<%= filters.q %>" placeholder="Rule ID or name"></label>
    <button class="secondary-btn" type="submit">Apply</button>
  </form>

  <section class="panel">
    <div class="table-wrap analyst-table-wrap"><table class="analyst-table">
      <thead><tr><th>Rule ID</th><th>Merchant</th><th>Rule Name</th><th>Risk Level</th><th class="num">Weight</th><th>Threshold</th><th>Rule Type</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody><% if (rows.length) { rows.forEach((rule) => { %>
        <tr><td><strong><%= rule.rule_id %></strong></td><td><%= rule.merchant_name || rule.merchant_id || 'All merchants' %></td><td><%= rule.rule_name %><div class="muted"><%= rule.reason %></div></td><td><span class="risk-badge risk-<%= String(rule.risk_level || 'low').toLowerCase() %>"><%= rule.risk_level %></span></td><td class="num"><%= rule.weight %></td><td><%= threshold(rule) %></td><td><%= rule.rule_type %></td><td><span class="status-pill <%= rule.is_active ? 'status-resolved' : 'status-critical' %>"><%= rule.is_active ? 'Active' : 'Inactive' %></span></td><td class="management-actions"><button class="secondary-btn" type="button" data-open-dialog="editRuleDialog-<%= rule.rule_id %>">Edit Rule</button><form method="post" action="/admin/rules/<%= rule.rule_id %>"><input type="hidden" name="isActive" value="<%= rule.is_active ? '0' : '1' %>"><button class="secondary-btn" type="submit"><%= rule.is_active ? 'Disable' : 'Enable' %></button></form><form method="post" action="/admin/rules/<%= rule.rule_id %>/delete"><button class="secondary-btn danger" type="submit" data-confirm="true">Delete</button></form></td></tr>
      <% }) } else { %><tr><td colspan="9" class="empty-inline">No rules match the selected filters.</td></tr><% } %></tbody>
    </table></div>
    <div class="pagination-row"><a class="secondary-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pageLink(Math.max(1, pagination.page - 1)) %>">Previous</a><span>Page <%= pagination.page %> of <%= pagination.totalPages %> &middot; <%= pagination.total %> records</span><a class="secondary-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" href="<%= pageLink(Math.min(pagination.totalPages, pagination.page + 1)) %>">Next</a></div>
  </section>
</main>

<dialog class="management-dialog" id="createRuleDialog"><form method="post" action="/admin/rules"><h2>Create Rule</h2><label><span>Rule ID</span><input name="ruleId" required></label><label><span>Merchant</span><select name="merchantId"><option value="">All merchants</option><% merchants.forEach((item) => { %><option value="<%= item.merchant_id %>"><%= item.merchant_name %></option><% }) %></select></label><label><span>Rule Name</span><input name="ruleName" required></label><label><span>Risk Level</span><select name="riskLevel"><option>Low</option><option>Medium</option><option>High</option><option>Critical</option></select></label><label><span>Reason</span><input name="reason" required></label><label><span>Weight</span><input name="weight" type="number" min="0" value="0"></label><label><span>Amount Threshold</span><input name="amountThreshold" type="number" step="0.01"></label><label><span>Count Threshold</span><input name="countThreshold" type="number"></label><label><span>Rule Type</span><input name="ruleType" value="runtime_rule"></label><label><span>Status</span><select name="isActive"><option value="1">Active</option><option value="0">Inactive</option></select></label><div class="modal-actions"><button class="secondary-btn" type="button" data-close-dialog>Cancel</button><button class="primary-btn" type="submit">Create Rule</button></div></form></dialog>
<% rows.forEach((rule) => { %><dialog class="management-dialog" id="editRuleDialog-<%= rule.rule_id %>"><form method="post" action="/admin/rules/<%= rule.rule_id %>"><h2>Edit Rule</h2><label><span>Merchant</span><select name="merchantId"><option value="">All merchants</option><% merchants.forEach((item) => { %><option value="<%= item.merchant_id %>" <%= rule.merchant_id === item.merchant_id ? 'selected' : '' %>><%= item.merchant_name %></option><% }) %></select></label><label><span>Rule Name</span><input name="ruleName" value="<%= rule.rule_name %>" required></label><label><span>Risk Level</span><select name="riskLevel"><% ['Low','Medium','High','Critical'].forEach((level) => { %><option value="<%= level %>" <%= rule.risk_level === level ? 'selected' : '' %>><%= level %></option><% }) %></select></label><label><span>Reason</span><input name="reason" value="<%= rule.reason %>" required></label><label><span>Weight</span><input name="weight" type="number" min="0" value="<%= rule.weight %>"></label><label><span>Amount Threshold</span><input name="amountThreshold" type="number" step="0.01" value="<%= rule.amount_threshold ?? '' %>"></label><label><span>Count Threshold</span><input name="countThreshold" type="number" value="<%= rule.count_threshold ?? '' %>"></label><label><span>Rule Type</span><input name="ruleType" value="<%= rule.rule_type %>"></label><label><span>Status</span><select name="isActive"><option value="1" <%= rule.is_active ? 'selected' : '' %>>Active</option><option value="0" <%= !rule.is_active ? 'selected' : '' %>>Inactive</option></select></label><div class="modal-actions"><button class="secondary-btn" type="button" data-close-dialog>Cancel</button><button class="primary-btn" type="submit">Save Changes</button></div></form></dialog><% }) %>
<script src="/management-dialogs.js"></script>
<%- include('partials/footer', { includeClientScript: true }) %>
