<%- include('partials/head', { title, activePage }) %>

<main>
  <section class="topbar">
    <div>
      <h1>Analytics</h1>
      <p>Review risk distribution, alert status, operational insights, and exposure trends.</p>
    </div>
  </section>
  <section class="filter-bar">
    <label for="companyFilter">Company</label>
    <select id="companyFilter" aria-label="Company filter">
      <option value="All">All Companies</option>
    </select>
  </section>

  <section class="chart-grid page-grid" id="charts">
    <div class="panel">
      <div class="panel-header"><div><h2>Risk Distribution</h2><p>Transactions by current risk band.</p></div></div>
      <div id="riskChart" class="bar-chart"></div>
    </div>
    <div class="panel">
      <div class="panel-header"><div><h2>Screening Outcome</h2><p>Flagged versus cleared transactions.</p></div></div>
      <div id="dispositionChart" class="bar-chart"></div>
    </div>
    <div class="panel">
      <div class="panel-header"><div><h2>Alert Status</h2><p>Operational status across all alerts.</p></div></div>
      <div id="alertStatusChart" class="bar-chart"></div>
    </div>
    <div class="panel">
      <div class="panel-header"><div><h2>Top Countries</h2><p>Highest transaction locations in the stream.</p></div></div>
      <div id="countryChart" class="bar-chart"></div>
    </div>
  </section>

  <section class="metrics analysis-metrics single-panel" id="analytics">
    <article><span>Flag Rate</span><strong id="analysisFlagRate">0%</strong></article>
    <article><span>High Risk Rate</span><strong id="analysisHighRiskRate">0%</strong></article>
    <article><span>Escalated Alerts</span><strong id="analysisEscalated">0</strong></article>
    <article><span>Overdue Cases</span><strong id="analysisOverdue">0</strong></article>
  </section>

  <section class="analysis-grid">
    <section class="panel">
      <div class="panel-header">
        <div>
          <h2>Key Insights</h2>
          <p>Operational signals for the current monitoring window.</p>
        </div>
      </div>
      <div id="analysisInsights" class="insight-list"></div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <div>
          <h2>Risk Drivers</h2>
          <p>Rules contributing most to flagged activity.</p>
        </div>
      </div>
      <div id="analysisDrivers" class="analysis-list"></div>
    </section>
  </section>

  <section class="analysis-grid single-panel">
    <section class="panel">
      <div class="panel-header">
        <div>
          <h2>Country Hotspots</h2>
          <p>Locations with the highest combined risk exposure.</p>
        </div>
      </div>
      <div id="analysisCountries" class="analysis-list"></div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <div>
          <h2>Company Exposure</h2>
          <p>Merchant risk concentration by company.</p>
        </div>
      </div>
      <div id="analysisCompanies" class="analysis-list"></div>
    </section>
  </section>

  <section class="panel single-panel">
    <div class="panel-header">
      <div>
        <h2>Customer Watchlist</h2>
        <p>Customers ranked by risk score, flagged count, and screened value.</p>
      </div>
    </div>
    <div id="analysisCustomers" class="analysis-list wide"></div>
  </section>
</main>

<%- include('partials/footer') %>
