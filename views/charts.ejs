<%- include('partials/head', { title, activePage }) %>

<main>
  <section class="topbar">
    <div>
      <h1>Compliance Charts</h1>
      <p>Monitor risk patterns and alert performance across the live transaction stream.</p>
    </div>
  </section>
  <section class="filter-bar">
    <label for="companyFilter">Company</label>
    <select id="companyFilter" aria-label="Company filter">
      <option value="All">All Companies</option>
    </select>
  </section>

  <section class="chart-grid page-grid" id="charts">
    <div class="panel">
      <div class="panel-header"><div><h2>Risk Distribution</h2><p>Transactions by current risk band.</p></div></div>
      <div id="riskChart" class="bar-chart"></div>
    </div>
    <div class="panel">
      <div class="panel-header"><div><h2>Screening Outcome</h2><p>Flagged versus cleared transactions.</p></div></div>
      <div id="dispositionChart" class="bar-chart"></div>
    </div>
    <div class="panel">
      <div class="panel-header"><div><h2>Alert Status</h2><p>Operational status across all alerts.</p></div></div>
      <div id="alertStatusChart" class="bar-chart"></div>
    </div>
    <div class="panel">
      <div class="panel-header"><div><h2>Top Countries</h2><p>Highest transaction locations in the stream.</p></div></div>
      <div id="countryChart" class="bar-chart"></div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>


