<%- include('partials/head', { title, activePage }) %>
<%
  const fmtDate = (value) => value ? new Date(value).toLocaleString('en-SG', { timeZone: 'Asia/Singapore' }) : 'Not assigned';
  const params = new URLSearchParams({ ...filters, actionType: query.actionType || '', userId: query.userId || '', userRole: query.userRole || '', entityType: query.entityType || '', dateFrom: query.dateFrom || '', dateTo: query.dateTo || '' });
  const pageLink = (page) => { const next = new URLSearchParams(params); next.set('page', page); return `/admin/audit-log?${next.toString()}`; };
%>
<main class="analyst-page admin-list-page admin-audit-page">
  <section class="analyst-page-header"><div><p class="detail-eyebrow">System administration</p><h1>Complete Audit Log</h1><p>Complete system audit history with pagination.</p></div><span class="role-chip">Admin</span></section>
  <form class="analyst-filter-bar" method="get">
    <label><span>Action Type</span><select name="actionType"><option value="">All</option><% actions.forEach((item) => { %><option value="<%= item.action %>" <%= query.actionType === item.action ? 'selected' : '' %>><%= item.action %></option><% }) %></select></label>
    <label><span>User</span><select name="userId"><option value="">All</option><% users.forEach((item) => { %><option value="<%= item.user_id %>" <%= query.userId === item.user_id ? 'selected' : '' %>><%= item.user_name %></option><% }) %></select></label>
    <label><span>Role</span><select name="userRole"><option value="">All</option><% ['Analyst','Senior Analyst','STRO','Admin'].forEach((item) => { %><option value="<%= item %>" <%= query.userRole === item ? 'selected' : '' %>><%= item %></option><% }) %></select></label>
    <label><span>Affected Entity</span><select name="entityType"><option value="">All</option><% entities.forEach((item) => { %><option value="<%= item.entity_type %>" <%= query.entityType === item.entity_type ? 'selected' : '' %>><%= item.entity_type %></option><% }) %></select></label>
    <label><span>From</span><input type="date" name="dateFrom" value="<%= query.dateFrom || '' %>"></label><label><span>To</span><input type="date" name="dateTo" value="<%= query.dateTo || '' %>"></label><label><span>Search</span><input name="q" value="<%= filters.q %>" placeholder="Transaction, case, action, notes"></label><button class="secondary-btn" type="submit">Apply</button>
  </form>
  <section class="panel"><div class="panel-header"><div><h2>Complete Audit Records</h2><p><%= pagination.total %> record<%= pagination.total === 1 ? '' : 's' %> match the current filters.</p></div></div><div class="table-wrap analyst-table-wrap"><table class="analyst-table"><thead><tr><th>Time</th><th>Action</th><th>User</th><th>Role</th><th>Affected Record</th><th>Notes</th></tr></thead><tbody><% if (rows.length) { rows.forEach((entry) => { %><tr><td><%= fmtDate(entry.created_at) %></td><td><span class="admin-action-badge"><%= entry.action %></span></td><td><%= entry.user_name || entry.user_id || 'System' %></td><td><span class="admin-role-badge admin-role-<%= String(entry.user_role || 'system').toLowerCase().replaceAll(' ', '-') %>"><%= entry.user_role || 'System' %></span></td><td><% if (entry.transaction_id) { %><a href="/transactions/<%= entry.transaction_id %>"><%= entry.transaction_id %></a><% } else if (entry.entity_type) { %><%= entry.entity_type %>: <%= entry.entity_id || 'Not assigned' %><% } else { %>Not assigned<% } %></td><td><%= entry.notes || 'No notes recorded' %></td></tr><% }) } else { %><tr><td colspan="6" class="empty-inline">No audit records match the selected filters.</td></tr><% } %></tbody></table></div><div class="pagination-row"><a class="secondary-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pageLink(Math.max(1, pagination.page - 1)) %>">Previous</a><span>Page <%= pagination.page %> of <%= pagination.totalPages %> &middot; <%= pagination.total %> records</span><a class="secondary-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" href="<%= pageLink(Math.min(pagination.totalPages, pagination.page + 1)) %>">Next</a></div></section>
</main>
<%- include('partials/footer', { includeClientScript: true }) %>
