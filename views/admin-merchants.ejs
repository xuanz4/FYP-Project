<%- include('partials/head', { title, activePage }) %>
<% const params = new URLSearchParams(filters); const pageLink = (page) => { const next = new URLSearchParams(params); next.set('page', page); return `/admin/merchants?${next.toString()}`; }; %>
<main class="analyst-page">
  <section class="analyst-page-header"><div><p class="detail-eyebrow">UNIWEB administration</p><h1>Merchant Management</h1><p>Create, edit or retire merchant monitoring profiles.</p></div><button class="primary-btn" type="button" data-open-dialog="createMerchantDialog">Create Merchant</button></section>
  <form class="analyst-filter-bar" method="get"><label><span>Status</span><select name="status"><option value="">All</option><option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option><option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option></select></label><label><span>Industry</span><select name="industry"><option value="">All</option><% industries.forEach((item) => { %><option value="<%= item.industry %>" <%= filters.industry === item.industry ? 'selected' : '' %>><%= item.industry %></option><% }) %></select></label><label><span>MCC</span><select name="mcc"><option value="">All</option><% mccs.forEach((item) => { %><option value="<%= item.mcc_code %>" <%= filters.mcc === item.mcc_code ? 'selected' : '' %>><%= item.mcc_code %></option><% }) %></select></label><label><span>Search</span><input name="q" value="<%= filters.q %>" placeholder="Merchant, ID, industry"></label><button class="secondary-btn" type="submit">Apply</button></form>
  <section class="panel"><div class="table-wrap analyst-table-wrap"><table class="analyst-table"><thead><tr><th>Merchant ID</th><th>Merchant Name</th><th>MID / Country</th><th>MCC</th><th>Industry</th><th class="num">Risk Score</th><th>EDD</th><th>Status</th><th>Actions</th></tr></thead><tbody><% if (rows.length) { rows.forEach((merchant) => { %><tr><td><strong><%= merchant.merchant_id %></strong></td><td><%= merchant.merchant_name %></td><td><%= merchant.merchant_mid || 'Not assigned' %><div class="muted"><%= merchant.merchant_country || '' %></div></td><td><%= merchant.mcc_code %></td><td><%= merchant.industry %></td><td class="num"><%= merchant.mcc_risk_score %></td><td><span class="status-pill <%= merchant.risk_tier === 'High' ? 'status-critical' : 'status-resolved' %>"><%= merchant.risk_tier %></span></td><td><span class="status-pill <%= merchant.is_active ? 'status-resolved' : 'status-critical' %>"><%= merchant.is_active ? 'Active' : 'Inactive' %></span></td><td class="management-actions"><button class="secondary-btn" type="button" data-open-dialog="editMerchantDialog-<%= merchant.merchant_id %>">Edit</button><form method="post" action="/admin/merchants/<%= merchant.merchant_id %>"><input type="hidden" name="isActive" value="<%= merchant.is_active ? '0' : '1' %>"><button class="secondary-btn" type="submit"><%= merchant.is_active ? 'Disable' : 'Enable' %></button></form><form method="post" action="/admin/merchants/<%= merchant.merchant_id %>/delete"><button class="secondary-btn danger" type="submit" data-confirm="true">Delete</button></form></td></tr><% }) } else { %><tr><td colspan="9" class="empty-inline">No merchants match the selected filters.</td></tr><% } %></tbody></table></div><div class="pagination-row"><a class="secondary-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pageLink(Math.max(1, pagination.page - 1)) %>">Previous</a><span>Page <%= pagination.page %> of <%= pagination.totalPages %> &middot; <%= pagination.total %> records</span><a class="secondary-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" href="<%= pageLink(Math.min(pagination.totalPages, pagination.page + 1)) %>">Next</a></div></section>
</main>
<dialog class="management-dialog" id="createMerchantDialog"><form method="post" action="/admin/merchants"><h2>Create Merchant</h2><label><span>Merchant ID</span><input name="merchantId" required></label><label><span>Merchant Name</span><input name="merchantName" required></label><label><span>Merchant MID</span><input name="merchantMid"></label><label><span>Country</span><input name="merchantCountry" value="SG" maxlength="2"></label><label><span>MCC</span><input name="mccCode" required></label><label><span>Industry</span><input name="industry" required></label><label><span>Risk Score</span><input name="mccRiskScore" type="number" min="0" value="0"></label><label><span>EDD Risk Tier</span><select name="riskTier"><option value="Standard">Standard</option><option value="High">High</option></select></label><label><span>Status</span><select name="isActive"><option value="1">Active</option><option value="0">Inactive</option></select></label><div class="modal-actions"><button class="secondary-btn" type="button" data-close-dialog>Cancel</button><button class="primary-btn" type="submit">Create Merchant</button></div></form></dialog>
<% rows.forEach((merchant) => { %><dialog class="management-dialog" id="editMerchantDialog-<%= merchant.merchant_id %>"><form method="post" action="/admin/merchants/<%= merchant.merchant_id %>"><h2>Edit Merchant</h2><label><span>Merchant Name</span><input name="merchantName" value="<%= merchant.merchant_name %>" required></label><label><span>Merchant MID</span><input name="merchantMid" value="<%= merchant.merchant_mid || '' %>"></label><label><span>Country</span><input name="merchantCountry" value="<%= merchant.merchant_country || '' %>" maxlength="2"></label><label><span>MCC</span><input name="mccCode" value="<%= merchant.mcc_code %>" required></label><label><span>Industry</span><input name="industry" value="<%= merchant.industry %>" required></label><label><span>Risk Score</span><input name="mccRiskScore" type="number" min="0" value="<%= merchant.mcc_risk_score %>"></label><label><span>EDD Risk Tier</span><select name="riskTier"><option value="Standard" <%= merchant.risk_tier === 'Standard' ? 'selected' : '' %>>Standard</option><option value="High" <%= merchant.risk_tier === 'High' ? 'selected' : '' %>>High</option></select></label><label><span>Status</span><select name="isActive"><option value="1" <%= merchant.is_active ? 'selected' : '' %>>Active</option><option value="0" <%= !merchant.is_active ? 'selected' : '' %>>Inactive</option></select></label><div class="modal-actions"><button class="secondary-btn" type="button" data-close-dialog>Cancel</button><button class="primary-btn" type="submit">Save Changes</button></div></form></dialog><% }) %>
<script src="/management-dialogs.js"></script>
<%- include('partials/footer', { includeClientScript: true }) %>
