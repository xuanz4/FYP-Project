<%- include('partials/head', { title, activePage }) %>
<% const params = new URLSearchParams(filters); const pageLink = (page) => { const next = new URLSearchParams(params); next.set('page', page); return `/admin/merchants?${next.toString()}`; };
   const toDateInputValue = (value) => { if (!value) return ''; const d = value instanceof Date ? value : new Date(value); return Number.isNaN(d.getTime()) ? '' : d.toISOString().slice(0, 10); };
   const kycStatuses = ['Not Started', 'Pending', 'Verified', 'Rejected'];
   const ownerRoles = ['Beneficial Owner', 'Authorised Representative', 'Director'];
   const screeningTypes = ['Sanctions', 'PEP', 'Adverse Media'];
   const screeningResults = ['Clear', 'Potential Match', 'Confirmed Match']; %>
<main class="analyst-page admin-list-page admin-merchants-page">
  <section class="analyst-page-header"><div><p class="detail-eyebrow">System administration</p><h1>Merchants</h1><p>Create, edit or retire merchant monitoring profiles.</p></div><button class="primary-btn" type="button" data-open-dialog="createMerchantDialog">Create Merchant</button></section>
  <form class="analyst-filter-bar" method="get"><label><span>Status</span><select name="status"><option value="">All</option><option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option><option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option></select></label><label><span>Industry</span><select name="industry"><option value="">All</option><% industries.forEach((item) => { %><option value="<%= item.industry %>" <%= filters.industry === item.industry ? 'selected' : '' %>><%= item.industry %></option><% }) %></select></label><label><span>MCC</span><select name="mcc"><option value="">All</option><% mccs.forEach((item) => { %><option value="<%= item.mcc_code %>" <%= filters.mcc === item.mcc_code ? 'selected' : '' %>><%= item.mcc_code %></option><% }) %></select></label><label><span>Search</span><input name="q" value="<%= filters.q %>" placeholder="Merchant, ID, industry"></label><button class="secondary-btn" type="submit">Apply</button></form>
  <section class="panel"><div class="panel-header"><div><h2>Merchant Records</h2><p><%= pagination.total %> merchant<%= pagination.total === 1 ? '' : 's' %> match the current filters.</p></div></div><div class="table-wrap analyst-table-wrap"><table class="analyst-table"><thead><tr><th>Merchant ID</th><th>Merchant Name</th><th>Industry</th><th>MCC</th><th>Risk Tier</th><th>KYC Status</th><th>Next Review</th><th>Status</th><th>Actions</th></tr></thead><tbody><% if (rows.length) { rows.forEach((merchant) => { %><tr><td><strong><%= merchant.merchant_id %></strong></td><td><%= merchant.merchant_name %></td><td><%= merchant.industry %></td><td><%= merchant.mcc_code %></td><td><span class="admin-tier-badge <%= merchant.risk_tier === 'High' ? 'tier-high' : 'tier-standard' %>"><%= merchant.risk_tier %></span></td><td><%= merchant.kyc_status || 'Not Started' %></td><td><%= toDateInputValue(merchant.next_review_date) || 'Not set' %></td><td><span class="admin-state-badge <%= merchant.is_active ? 'is-active' : 'is-inactive' %>"><%= merchant.is_active ? 'Active' : 'Inactive' %></span></td><td class="management-actions"><button class="secondary-btn" type="button" data-open-dialog="editMerchantDialog-<%= merchant.merchant_id %>">Edit</button><form method="post" action="/admin/merchants/<%= merchant.merchant_id %>"><input type="hidden" name="isActive" value="<%= merchant.is_active ? '0' : '1' %>"><button class="secondary-btn" type="submit"><%= merchant.is_active ? 'Disable' : 'Enable' %></button></form><form method="post" action="/admin/merchants/<%= merchant.merchant_id %>/delete"><button class="secondary-btn danger" type="submit" data-confirm="true">Delete</button></form></td></tr><% }) } else { %><tr><td colspan="9" class="empty-inline">No merchants match the selected filters.</td></tr><% } %></tbody></table></div><div class="pagination-row"><a class="secondary-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pageLink(Math.max(1, pagination.page - 1)) %>">Previous</a><span>Page <%= pagination.page %> of <%= pagination.totalPages %> &middot; <%= pagination.total %> records</span><a class="secondary-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" href="<%= pageLink(Math.min(pagination.totalPages, pagination.page + 1)) %>">Next</a></div></section>
</main>
<dialog class="management-dialog" id="createMerchantDialog"><form method="post" action="/admin/merchants"><h2>Create Merchant</h2><label><span>Merchant ID</span><input name="merchantId" required></label><label><span>Merchant Name</span><input name="merchantName" required></label><label><span>Merchant MID</span><input name="merchantMid"></label><label><span>Country</span><input name="merchantCountry" value="SG" maxlength="2"></label><label><span>MCC</span><input name="mccCode" required></label><label><span>Industry</span><input name="industry" required></label><label><span>Risk Score</span><input name="mccRiskScore" type="number" min="0" value="0"></label><label><span>EDD Risk Tier</span><select name="riskTier"><option value="Standard">Standard</option><option value="High">High</option></select></label><label><span>Status</span><select name="isActive"><option value="1">Active</option><option value="0">Inactive</option></select></label>
  <p class="detail-eyebrow">RFI contact record (merchant_contacts)</p><label><span>Contact Person</span><input name="contactName"></label><label><span>RFI Email</span><input name="rfiEmail" type="email"></label><label><span>Phone Number</span><input name="phoneNumber"></label><label><span>Store ID</span><input name="contactStoreId"></label>
  <p class="detail-eyebrow">CDD profile (self-declared / admin-recorded - no live KYC provider in this project's scope)</p><label><span>KYC Status</span><select name="kycStatus"><% kycStatuses.forEach((status) => { %><option value="<%= status %>" <%= status === 'Not Started' ? 'selected' : '' %>><%= status %></option><% }) %></select></label><label><span>Verification Date</span><input name="verificationDate" type="date"></label><label><span>Next Review Date</span><input name="nextReviewDate" type="date"></label>
  <p class="detail-eyebrow">Expected activity (drives declared-ticket, operating-hours and foreign-country detection thresholds once on file - see riskEngine.js)</p><label><span>Expected Monthly Volume (SGD)</span><input name="expectedMonthlyVolume" type="number" min="0" step="0.01"></label><label><span>Expected Avg Ticket (SGD)</span><input name="expectedAvgTicket" type="number" min="0" step="0.01"></label><label><span>Expected Countries (comma-separated ISO codes)</span><input name="expectedCountries" placeholder="SG, MY"></label><label><span>Expected Operating Hours - Open</span><input name="expectedOperatingOpenHour" type="number" min="0" max="23"></label><label><span>Expected Operating Hours - Close</span><input name="expectedOperatingCloseHour" type="number" min="0" max="23"></label>
  <div class="modal-actions"><button class="secondary-btn" type="button" data-close-dialog>Cancel</button><button class="primary-btn" type="submit">Create Merchant</button></div></form></dialog>
<% rows.forEach((merchant) => {
     const owners = beneficialOwnersByMerchant[merchant.merchant_id] || [];
     const screenings = screeningRecordsByMerchant[merchant.merchant_id] || []; %>
<dialog class="management-dialog" id="editMerchantDialog-<%= merchant.merchant_id %>">
  <!-- Single form with formaction-per-button on each submit control: the dialog CSS
       (.management-dialog > form) assumes exactly one direct-child form, and each button here
       posts only to its own endpoint - the extra fields from other sections in the payload are
       simply ignored by whichever controller handles that button's formaction. -->
  <form method="post" action="/admin/merchants/<%= merchant.merchant_id %>"><h2>Edit Merchant</h2><label><span>Merchant Name</span><input name="merchantName" value="<%= merchant.merchant_name %>" required></label><label><span>Merchant MID</span><input name="merchantMid" value="<%= merchant.merchant_mid || '' %>"></label><label><span>Country</span><input name="merchantCountry" value="<%= merchant.merchant_country || '' %>" maxlength="2"></label><label><span>MCC</span><input name="mccCode" value="<%= merchant.mcc_code %>" required></label><label><span>Industry</span><input name="industry" value="<%= merchant.industry %>" required></label><label><span>Risk Score</span><input name="mccRiskScore" type="number" min="0" value="<%= merchant.mcc_risk_score %>"></label><label><span>EDD Risk Tier</span><select name="riskTier"><option value="Standard" <%= merchant.risk_tier === 'Standard' ? 'selected' : '' %>>Standard</option><option value="High" <%= merchant.risk_tier === 'High' ? 'selected' : '' %>>High</option></select></label><label><span>Status</span><select name="isActive"><option value="1" <%= merchant.is_active ? 'selected' : '' %>>Active</option><option value="0" <%= !merchant.is_active ? 'selected' : '' %>>Inactive</option></select></label>
    <p class="detail-eyebrow">RFI contact record (merchant_contacts) - always looked up live, never cached</p><label><span>Contact Person</span><input name="contactName" value="<%= merchant.contact_name || '' %>"></label><label><span>RFI Email</span><input name="rfiEmail" type="email" value="<%= merchant.rfi_email || '' %>"></label><label><span>Phone Number</span><input name="phoneNumber" value="<%= merchant.phone_number || '' %>"></label><label><span>Store ID</span><input name="contactStoreId" value="<%= merchant.contact_store_id || '' %>"></label>
    <p class="detail-eyebrow">CDD profile (self-declared / admin-recorded - Analysts see this read-only on the case workspace)</p><label><span>KYC Status</span><select name="kycStatus"><% kycStatuses.forEach((status) => { %><option value="<%= status %>" <%= (merchant.kyc_status || 'Not Started') === status ? 'selected' : '' %>><%= status %></option><% }) %></select></label><label><span>Verification Date</span><input name="verificationDate" type="date" value="<%= toDateInputValue(merchant.verification_date) %>"></label><label><span>Next Review Date</span><input name="nextReviewDate" type="date" value="<%= toDateInputValue(merchant.next_review_date) %>"></label>
    <p class="detail-eyebrow">Expected activity (drives declared-ticket, operating-hours and foreign-country detection thresholds once on file)</p><label><span>Expected Monthly Volume (SGD)</span><input name="expectedMonthlyVolume" type="number" min="0" step="0.01" value="<%= merchant.expected_monthly_volume ?? '' %>"></label><label><span>Expected Avg Ticket (SGD)</span><input name="expectedAvgTicket" type="number" min="0" step="0.01" value="<%= merchant.expected_avg_ticket ?? '' %>"></label><label><span>Expected Countries (comma-separated ISO codes)</span><input name="expectedCountries" value="<%= merchant.expected_countries || '' %>" placeholder="SG, MY"></label><label><span>Expected Operating Hours - Open</span><input name="expectedOperatingOpenHour" type="number" min="0" max="23" value="<%= merchant.expected_operating_open_hour ?? '' %>"></label><label><span>Expected Operating Hours - Close</span><input name="expectedOperatingCloseHour" type="number" min="0" max="23" value="<%= merchant.expected_operating_close_hour ?? '' %>"></label>
    <div class="modal-actions"><button class="secondary-btn" type="button" data-close-dialog>Cancel</button><button class="primary-btn" type="submit" formaction="/admin/merchants/<%= merchant.merchant_id %>">Save Changes</button></div>

    <% if (merchant.risk_tier === 'High') { %>
    <p class="detail-eyebrow">EDD baseline checks (Enhanced Verification and final sign-off are completed by a Senior Analyst in the case workspace)</p>
    <label class="checkbox-field"><input type="checkbox" name="sourceOfFundsCompleted" value="1" <%= merchant.source_of_funds_verified ? 'checked' : '' %>><span>Source of Funds Verified</span></label><input name="sourceOfFundsNotes" placeholder="Notes" value="<%= merchant.source_of_funds_notes || '' %>">
    <label class="checkbox-field"><input type="checkbox" name="siteVisitCompleted" value="1" <%= merchant.site_visit_completed ? 'checked' : '' %>><span>Site Visit or Equivalent Check Completed</span></label><input name="siteVisitNotes" placeholder="Notes" value="<%= merchant.site_visit_notes || '' %>">
    <div class="modal-actions"><button class="primary-btn" type="submit" formaction="/admin/merchants/<%= merchant.merchant_id %>/edd-checklist">Save Checklist</button></div>
    <% } %>

    <p class="detail-eyebrow">Beneficial owners / authorised representatives (self-declared, not independently verified)</p>
    <ul class="admin-inline-list"><% if (owners.length) { owners.forEach((owner) => { %><li><strong><%= owner.full_name %></strong> - <%= owner.owner_role %><% if (owner.ownership_percentage) { %> (<%= owner.ownership_percentage %>%)<% } %><% if (owner.nationality) { %>, <%= owner.nationality %><% } %><% if (owner.id_reference) { %>, ref <%= owner.id_reference %><% } %> <button class="secondary-btn danger" type="submit" formaction="/admin/merchants/<%= merchant.merchant_id %>/beneficial-owners/<%= owner.owner_id %>/delete" data-confirm="true">Remove</button></li><% }) } else { %><li class="empty-inline">No beneficial owners or authorised representatives on file.</li><% } %></ul>
    <label><span>Full Name</span><input name="fullName"></label><label><span>Role</span><select name="ownerRole"><% ownerRoles.forEach((r) => { %><option value="<%= r %>"><%= r %></option><% }) %></select></label><label><span>Ownership %</span><input name="ownershipPercentage" type="number" min="0" max="100" step="0.01"></label><label><span>Nationality</span><input name="nationality"></label><label><span>ID Reference (self-declared)</span><input name="idReference"></label><label><span>Date of Birth</span><input name="dateOfBirth" type="date"></label><div class="modal-actions"><button class="secondary-btn" type="submit" formaction="/admin/merchants/<%= merchant.merchant_id %>/beneficial-owners">Add Owner</button></div>

    <p class="detail-eyebrow">Screening records (manual attestation - no live sanctions/PEP/adverse-media API in this project's scope)</p>
    <ul class="admin-inline-list">
      <% if (screenings.length) { screenings.forEach((record) => { %>
        <li class="screening-record-item">
          <strong><%= record.screening_type %>:</strong>
          <span><%= record.result %><% if (record.screened_against) { %> vs <%= record.screened_against %><% } %><% if (record.notes) { %> - <%= record.notes %><% } %></span>
        </li>
      <% }) } else { %>
        <li class="empty-inline">No screening records on file.</li>
      <% } %>
    </ul>
    <label><span>Screening Type</span><select name="screeningType"><% screeningTypes.forEach((t) => { %><option value="<%= t %>"><%= t %></option><% }) %></select></label><label><span>Result</span><select name="result"><% screeningResults.forEach((r) => { %><option value="<%= r %>"><%= r %></option><% }) %></select></label><label><span>Screened Against (source)</span><input name="screenedAgainst" placeholder="e.g. UN Consolidated List"></label><label><span>Notes</span><input name="notes"></label><div class="modal-actions"><button class="secondary-btn" type="submit" formaction="/admin/merchants/<%= merchant.merchant_id %>/screening">Add Screening Record</button></div>
  </form>
</dialog>
<% }) %>
<script src="/management-dialogs.js"></script>
<%- include('partials/footer', { includeClientScript: true }) %>
